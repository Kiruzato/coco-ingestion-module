# ============================================
INGESTION_MODULE/.venv/
# === Windows artifacts ===
nul
Thumbs.db

# === macOS ===
.DS_Store

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# === Virtual environments ===
venv/
venv311/
ENV/
.venv/
INGESTION_MODULE/venv/

# === Environment files (keep .env.example) ===
.env
*.env.local

# === IDE ===
.vscode/
.idea/
*.swp
*.swo

# === Logs ===
*.log

